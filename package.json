  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter shared build && pnpm --filter api build && pnpm --filter web build",
    "fmt": "pnpm -r fmt",
    "fmt:check": "pnpm -r fmt:check",
    "check": "pnpm -r check"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0"
  }
}
